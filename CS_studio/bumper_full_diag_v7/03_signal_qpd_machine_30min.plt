    <formula>
      <display_name>2.5 blue: L4 QPD σx, 0.03·Δµm</display_name>
      <visible>true</visible>
      <name>qpd_l4x</name>
      <axis>1</axis>
      <color>
        <red>31</red>
        <green>119</green>
        <blue>180</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
