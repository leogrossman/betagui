    <formula>
      <display_name>0.5 green: L2 QPD σx, 0.05·Δµm</display_name>
      <visible>true</visible>
      <name>qpd_l2x</name>
      <axis>1</axis>
      <color>
        <red>44</red>
        <green>160</green>
        <blue>44</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>0.5+0.05*(l2x-377.2)</formula>
      <input>
        <pv>QPD01ZL2RP:rdSigmaXav</pv>
        <name>l2x</name>
      </input>
      <input>
        <pv>QPD01ZL2RP:rdSigmaYav</pv>
