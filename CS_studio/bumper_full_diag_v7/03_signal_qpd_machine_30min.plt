    </formula>
    <formula>
      <display_name>1.5 darkgreen: L2 QPD σy, 1.0·Δµm</display_name>
      <visible>true</visible>
      <name>qpd_l2y</name>
      <axis>1</axis>
      <color>
        <red>0</red>
        <green>120</green>
        <blue>0</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
