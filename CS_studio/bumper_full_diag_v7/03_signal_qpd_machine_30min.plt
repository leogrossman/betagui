      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>1.5+1.0*(l2y-116.9)</formula>
      <input>
        <pv>QPD01ZL2RP:rdSigmaXav</pv>
        <name>l2x</name>
      </input>
      <input>
        <pv>QPD01ZL2RP:rdSigmaYav</pv>
        <name>l2y</name>
