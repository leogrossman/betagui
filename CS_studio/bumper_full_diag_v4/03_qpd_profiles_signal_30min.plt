    </pv>
    <pv>
      <display_name>1 + 0.05·(σx L2 - σx L4)</display_name>
      <visible>true</visible>
      <name>=0.05*(pv(&quot;QPD01ZL2RP:rdSigmaXav&quot;)-pv(&quot;QPD00ZL4RP:rdSigmaXav&quot;))+1.0</name>
      <axis>1</axis>
      <color>
        <red>148</red>
        <green>103</green>
        <blue>189</blue>
      </color>
      <trace_type>LINE</trace_type>
      <linewidth>3</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <period>0.0</period>
      <ring_size>259200</ring_size>
      <request>OPTIMIZED</request>
    </pv>
    <pv>
      <display_name>2.5 + 0.05·(σy L2 - σy L4)</display_name>
      <visible>true</visible>
      <name>=0.05*(pv(&quot;QPD01ZL2RP:rdSigmaYav&quot;)-pv(&quot;QPD00ZL4RP:rdSigmaYav&quot;))+2.5</name>
