    <formula>
      <display_name>0.5 + 0.02*sum(I^2)</display_name>
      <visible>true</visible>
      <name>0.5 + 0.02*sum(I^2)</name>
      <axis>1</axis>
      <color>
        <red>140</red>
        <green>86</green>
        <blue>75</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>0.5 + 0.02*(i1*i1+i2*i2+i3*i3+i4*i4)</formula>
      <input>
        <pv>HS1P1K1RP:setCur</pv>
        <name>i1</name>
      </input>
      <input>
        <pv>HS1P2K3RP:setCur</pv>
        <name>i2</name>
      </input>
      <input>
        <pv>HS3P1L4RP:setCur</pv>
        <name>i3</name>
      </input>
      <input>
        <pv>HS3P2L4RP:setCur</pv>
        <name>i4</name>
      </input>
    </formula>
    <formula>
      <display_name>1.7 + 0.2*sum(|I|)</display_name>
      <visible>true</visible>
      <name>1.7 + 0.2*sum(|I|)</name>
      <axis>1</axis>
      <color>
        <red>148</red>
        <green>103</green>
        <blue>189</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>1.7 + 0.2*(abs(i1)+abs(i2)+abs(i3)+abs(i4))</formula>
      <input>
        <pv>HS1P1K1RP:setCur</pv>
        <name>i1</name>
      </input>
      <input>
        <pv>HS1P2K3RP:setCur</pv>
        <name>i2</name>
      </input>
      <input>
