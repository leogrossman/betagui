      <formula>0.5*((x3 + ((x4-x3)/0.8594)*(12.0-8.1872)) + (x5 + ((x6-x5)/0.9006)*(12.0-14.9534))) - (0.5*(((-0.07) + (((-0.19)-(-0.07))/0.8594)*(12.0-8.1872)) + ((-0.76) + (((-0.16)-(-0.76))/0.9006)*(12.0-14.9534))))</formula>
      <input>
