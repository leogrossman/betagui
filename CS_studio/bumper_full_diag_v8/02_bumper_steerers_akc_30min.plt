        <name>i4</name>
      </input>
    </formula>
    <formula>
      <display_name>5 black: common-mode ΔI, 20000×mean ΔA +5</display_name>
      <visible>true</visible>
      <name>I_common</name>
      <axis>0</axis>
      <color>
        <red>0</red>
        <green>0</green>
        <blue>0</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>3</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>5 + 20000*0.25*((i1-0.064022)+(i2-0.23767)+(i3+0.089934)+(i4+0.016475))</formula>
      <input>
        <pv>HS1P2K3RP:setCur</pv>
        <name>i1</name>
      </input>
      <input>
        <pv>HS3P1L4RP:setCur</pv>
