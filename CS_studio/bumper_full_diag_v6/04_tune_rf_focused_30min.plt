    <formula>
      <display_name>0.8 + 1000·(νx−0.1779)</display_name>
      <visible>true</visible>
      <name>mtune_x</name>
      <axis>1</axis>
      <color>
        <red>255</red>
        <green>127</green>
        <blue>14</blue>
      </color>
      <trace_type>AREA</trace_type>
      <linewidth>2</linewidth>
      <line_style>SOLID</line_style>
      <point_type>NONE</point_type>
      <point_size>2</point_size>
      <waveform_index>0</waveform_index>
      <formula>0.8+1000.0*(nux-0.1779)</formula>
      <input>
        <pv>TUNEZRP:measX</pv>
        <name>nux</name>
      </input>
      <input>
        <pv>TUNEZRP:measY</pv>
        <name>nuy</name>
      </input>
      <input>
        <pv>TUNEZRP:measZ</pv>
        <name>nuz</name>
      </input>
    </formula>
    <formula>
      <display_name>2.0 + 1000·(νy−0.2200)</display_name>
      <visible>true</visible>
      <name>mtune_y</name>
      <axis>1</axis>
      <color>
